# API Keys and Secrets
# Copy this file to .env and fill in your values

# SEC-API.io API Key (for insider trading data)
# Get your key at: https://sec-api.io/
SEC_API_KEY=your_sec_api_key_here

# EDGAR User Agent (if using EDGAR directly)
# Format: "YourName/1.0 (your@email.com)"
EDGAR_USER_AGENT=YourName/1.0 (your@email.com)

# Alpaca Paper Trading Credentials
# Get your keys at: https://alpaca.markets/
# IMPORTANT: Always use paper trading keys for testing!
ALPACA_API_KEY=your_alpaca_paper_api_key
ALPACA_API_SECRET=your_alpaca_paper_api_secret

# Paper Trading Mode
# ALWAYS set to "true" for paper trading
# Never run with real money without thorough testing
PAPER_MODE=true
