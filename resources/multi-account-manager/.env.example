# ============================================================
# Multi-Account Strategy Manager — Environment Variables
# ============================================================
# Copy this file to .env and fill in your PAPER trading keys.
# NEVER commit .env to git!
# ============================================================

# --- Account 1: tradingView ---
TRADINGVIEW_API_KEY=your_paper_api_key_here
TRADINGVIEW_API_SECRET=your_paper_api_secret_here

# --- Account 2: bitcoin4H ---
BITCOIN4H_API_KEY=your_paper_api_key_here
BITCOIN4H_API_SECRET=your_paper_api_secret_here

# --- Account 3: fvg ---
FVG_API_KEY=your_paper_api_key_here
FVG_API_SECRET=your_paper_api_secret_here

# --- Capital ---
INITIAL_CAPITAL_PER_ACCOUNT_USD=5000

# --- Risk Guardrails ---
MAX_POSITION_VALUE_USD=2500
MAX_DAILY_LOSS_USD=500
MAX_ORDERS_PER_DAY=50

# --- Dashboard ---
DASHBOARD_PORT=8050
API_PORT=8051

# --- General ---
TIMEZONE=America/New_York
SCAN_INTERVAL_SECONDS=60
